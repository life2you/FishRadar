################################################################################
# 🗄️ 1. 数据库配置
# 当前版本仅支持 MySQL。
################################################################################

# MySQL 连接串（推荐）
# 例如: mysql://fishradar:fishradar123@127.0.0.1:3306/fishradar?charset=utf8mb4
APP_DATABASE_URL=


################################################################################
# 🤖 2. AI 说明
# 当前版本的 AI 账号、图片/文本能力、优先级等，都应在管理员后台里配置。
# 下列 OPENAI_* 变量不再作为应用运行时主配置，仅保留作历史兼容参考。
################################################################################

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=


################################################################################
# 🖥️ 3. Web 管理界面配置
# 用于访问控制台，保护你的配置不被他人篡改。
################################################################################

# 服务运行端口 (默认 8000)
SERVER_PORT=8000

# 运行环境：development / production
APP_ENV=development

# 管理员账号与密码 (默认 admin / admin123)
WEB_USERNAME=admin
WEB_PASSWORD=admin123

# 生产环境建议开启强约束：空库首次启动时若仍使用默认管理员口令则拒绝启动
ENFORCE_PRODUCTION_ADMIN_BOOTSTRAP_SAFETY=true

# 是否强制给登录 Cookie 增加 Secure 标记
# 生产环境默认会自动启用，即使这里不手动设置
AUTH_COOKIE_SECURE=false

# 登录失败限流：按来源 IP 统计
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900


################################################################################
# 🕷️ 4. 爬虫基础设置
# 控制浏览器的运行行为。
################################################################################

# 爬虫是否以无头模式运行 (默认 true)。
# 注意：使用 Docker 部署时必须设为 true。
RUN_HEADLESS=true

# 是否使用 Edge 浏览器内核 (默认 false, 即使用 Chrome)。
# 仅影响本地浏览器通道；Docker 镜像未内置 Edge，容器内会固定使用 Chromium。
LOGIN_IS_EDGE=false

# 是否开启自动转换：将电脑端链接转换为手机端链接 (建议开启)
PCURL_TO_MOBILE=true


################################################################################
# 🛠️ 5. AI 运行参数 (建议后续改在后台维护)
# 这些参数当前已支持入库，首次启动时会从 .env 导入一次。
# 导入后建议以后都从后台设置页维护，而不是持续改 .env。
################################################################################

# AI 调试模式 (默认 false)。开启后控制台会打印详细的 AI 分析日志。
AI_DEBUG_MODE=false

# (可选) 为 AI 请求配置 HTTP/S 代理。支持 http 和 socks5。
# 例如: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
PROXY_URL=""

# 是否启用 enable_thinking 参数 (某些模型如 DeepSeek 可能需要，默认 false)
ENABLE_THINKING=false

# 是否启用 response_format (默认 true)。
# 豆包模型等不支持 json_object 格式的需设为 false；Gemini/GPT 等建议设为 true。
ENABLE_RESPONSE_FORMAT=true


################################################################################
# 📢 6. 消息推送配置 (建议后续改在后台维护)
# 平台通知配置当前已支持入库，首次启动时会从 .env 导入一次。
# 导入后建议以后都从后台设置页维护。
################################################################################

# --- ntfy (推荐) ---
NTFY_TOPIC_URL=

# --- Bark (iOS 推荐) ---
# 例如: https://api.day.app/your_key
BARK_URL=

# --- 企业微信机器人 ---
WX_BOT_URL=

# --- Telegram 机器人 ---
# 获取 Token 找 @BotFather，获取 Chat ID 找 @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 可选：Telegram Bot API 反代地址，默认 https://api.telegram.org
TELEGRAM_API_BASE_URL=

# --- Gotify ---
GOTIFY_URL=
GOTIFY_TOKEN=

# --- 通用 Webhook ---
WEBHOOK_URL=
WEBHOOK_METHOD="POST"
WEBHOOK_CONTENT_TYPE="JSON"
WEBHOOK_HEADERS='{"X-API-TOKEN":"your-secret-token"}'
WEBHOOK_QUERY_PARAMETERS='{"title":"{{title}}","content":"{{content}}"}'
WEBHOOK_BODY='{"title":"{{title}}","content":"{{content}}"}'


################################################################################
# 🛡️ 7. 高级功能
# 轮换配置与失败熔断阈值当前也已支持入库，首次启动时会从 .env 导入一次。
################################################################################

# --- 任务失败保护 ---
# 当任务持续失败(如 Cookie 失效)时，自动暂停避免风控。
TASK_FAILURE_THRESHOLD=3
TASK_FAILURE_PAUSE_SECONDS=86400

# --- 任务运行日志清理 ---
# 启动时自动清理 logs/*.log 中超过保留天数的历史日志（默认 7 天）
TASK_LOG_RETENTION_DAYS=7

# --- 代理池轮换 ---
PROXY_ROTATION_ENABLED=false
# per_task 或 on_failure
PROXY_ROTATION_MODE="per_task"
PROXY_POOL=""
PROXY_ROTATION_RETRY_LIMIT=2
PROXY_BLACKLIST_TTL=300
